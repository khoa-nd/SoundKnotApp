{
  "expo": {
    "name": "SoundKnot",
    "slug": "soundknot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soundknot",
"userInterfaceStyle": "automatic",
  "newArchEnabled": true,
  "splash": {
    "image": "./assets/images/splash-icon.png",
    "resizeMode": "contain",
    "backgroundColor": "#F4F3EE"
  },
  "ios": {
    "supportsTablet": true,
    "infoPlist": {
      "UIBackgroundModes": ["audio"],
      "NSMicrophoneUsageDescription": "SoundKnot uses the microphone for voice commands and pronunciation practice."
    }
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/images/adaptive-icon.png",
      "backgroundColor": "#F4F3EE"
    },
      "edgeToEdgeEnabled": true,
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
